<?xml version="1.0" encoding="UTF-8" standalone="no"?>
<ns2:Document xmlns:ns2="urn:iso:std:iso:20022:tech:xsd:acmt.023.001.04"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="urn:iso:std:iso:20022:tech:xsd:acmt.023.001.04 ">
    <IdVrfctnReq>
        <Assgnmt>
            <!-- Unique message reference as generated by sending party. -->
            <MsgId>{Properly Formatted MsgId}</MsgId> <!-- Mandatory Field -->
            <!-- Document creation local date-time -->
            <CreDtTm>{DateTime in ISO-8601 format}</CreDtTm> <!-- Mandatory Field -->
            <Cretr>
                <Pty>
                    <Nm>{Name of Sending Party}</Nm> <!-- Mandatory Field -->
                </Pty>
            </Cretr>
            <Assgnr>
                <Pty>
                    <Nm>{Name of Sending Party}</Nm> <!-- Mandatory Field -->
                </Pty>
                <Agt>
                    <FinInstnId>
                        <BICFI>{SourceID}</BICFI> <!-- Optional Field -->
                        <ClrSysMmbId>
                            <MmbId>{SourceId}</MmbId> <!-- Mandatory Field -->
                        </ClrSysMmbId>
                    </FinInstnId>
                </Agt>
            </Assgnr>
            <Assgne>
                <Agt>
                    <FinInstnId>
                        <BICFI>{BeneficiaryID}</BICFI> <!-- Optional Field -->
                        <ClrSysMmbId>
                            <MmbId>{BeneficiaryID}</MmbId> <!-- Mandatory Field -->
                        </ClrSysMmbId>
                    </FinInstnId>
                </Agt>
            </Assgne>
        </Assgnmt>
        <Vrfctn>
            <Id>--Same as MsgId----</Id> <!-- Mandatory Field -->
            <PtyAndAcctId>
                <Pty>
                    <Nm>{Name of Party to be Verified}</Nm> <!-- Mandatory Field -->
                </Pty>
                <Acct>
                    <Id>
                        <IBAN>{Account Number of Party to be Verified}</IBAN> <!-- Mandatory Field -->
                    </Id>
                </Acct>
            </PtyAndAcctId>
        </Vrfctn>
    </IdVrfctnReq>
</ns2:Document>